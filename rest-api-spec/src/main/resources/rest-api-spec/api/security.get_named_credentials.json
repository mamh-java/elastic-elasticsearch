{
  "security.get_named_credentials": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-security-get-named-credentials",
      "description": "Get one or all named credentials with secrets redacted"
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": ["application/json"]
    },
    "url": {
      "paths": [
        {
          "path": "/_security/named_credentials/{name}",
          "methods": ["GET"],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the credential"
            }
          }
        },
        {
          "path": "/_security/named_credentials",
          "methods": ["GET"]
        }
      ]
    }
  }
}
