{
  "security.delete_named_credential": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-security-delete-named-credential",
      "description": "Delete a named credential"
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": ["application/json"]
    },
    "url": {
      "paths": [
        {
          "path": "/_security/named_credentials/{name}",
          "methods": ["DELETE"],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the credential"
            }
          }
        }
      ]
    }
  }
}
