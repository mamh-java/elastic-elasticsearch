{
  "security.decrypt_named_credential": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-security-decrypt-named-credential",
      "description": "Get a named credential with its secrets decrypted to plaintext"
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": ["application/json"]
    },
    "url": {
      "paths": [
        {
          "path": "/_security/named_credentials/{name}/_decrypt",
          "methods": ["GET"],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the credential"
            }
          }
        }
      ]
    }
  }
}
