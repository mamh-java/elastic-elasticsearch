{
  "security.put_named_credential": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-security-put-named-credential",
      "description": "Create or replace a named credential"
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": ["application/json"],
      "content_type": ["application/json"]
    },
    "url": {
      "paths": [
        {
          "path": "/_security/named_credentials/{name}",
          "methods": ["PUT"],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the credential"
            }
          }
        }
      ]
    },
    "body": {
      "description": "The credential definition: auth_type, optional url and config, and the auth secrets block",
      "required": true
    }
  }
}
