{
  "security.patch_named_credential": {
    "documentation": {
      "url": "https://www.elastic.co/docs/api/doc/elasticsearch/operation/operation-security-patch-named-credential",
      "description": "Partially update an existing named credential"
    },
    "stability": "experimental",
    "visibility": "public",
    "headers": {
      "accept": ["application/json"],
      "content_type": ["application/json"]
    },
    "url": {
      "paths": [
        {
          "path": "/_security/named_credentials/{name}",
          "methods": ["PATCH"],
          "parts": {
            "name": {
              "type": "string",
              "description": "The name of the credential"
            }
          }
        }
      ]
    },
    "body": {
      "description": "The fields to update: any combination of auth_type, url, config, and auth. At least one field must be provided.",
      "required": true
    }
  }
}
