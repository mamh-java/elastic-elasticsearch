// Opaque many / concrete one: the LHS keeps per-series identity; pod survives as
// an output column materialized from the LHS (the one side has no pod to copy).
// Same numbers as vector_match_group_left.
vector_match_matrix_opaque_many_group_left
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(network.eth0.tx / on (cluster) group_left (pod) sum by (cluster) (network.eth0.rx))
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double            | cluster:keyword | pod:keyword | step:datetime
