// 1:1 match on (cluster): ratio[cluster, step] = numerator / denominator for the same (cluster, step).
vector_match_on_cluster
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m ratio=(sum by (cluster) (network.eth0.tx) / on (cluster) sum by (cluster) (network.eth0.rx))
| SORT cluster, step;

ratio:double       | step:datetime            | cluster:keyword
1.103305785123967  | 2024-05-10T00:10:00.000Z | prod
1.1411513859275053 | 2024-05-10T00:20:00.000Z | prod
1.16072408118486   | 2024-05-10T00:30:00.000Z | prod
0.9730554143365532 | 2024-05-10T00:10:00.000Z | qa
1.219419184511587  | 2024-05-10T00:20:00.000Z | qa
1.1905023332418336 | 2024-05-10T00:30:00.000Z | qa
0.9343173431734317 | 2024-05-10T00:10:00.000Z | staging
1.0426854537919603 | 2024-05-10T00:20:00.000Z | staging
0.9903225806451613 | 2024-05-10T00:30:00.000Z | staging
;

// on(cluster) with opaque operands: `without` packs each operand's identity into _timeseries with no label columns
// of its own; the on(cluster) demand materializes the label as a concrete column to key the join on. The k8s label
// universe is (cluster, pod, region), so `without (pod, region)` matches vector_match_on_cluster exactly.
vector_match_on_cluster_opaque_operands
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m ratio=(sum without (pod, region) (network.eth0.tx) / on (cluster) sum without (pod, region) (network.eth0.rx))
| KEEP ratio, step, cluster
| SORT cluster, step;

ratio:double       | step:datetime            | cluster:keyword
1.103305785123967  | 2024-05-10T00:10:00.000Z | prod
1.1411513859275053 | 2024-05-10T00:20:00.000Z | prod
1.16072408118486   | 2024-05-10T00:30:00.000Z | prod
0.9730554143365532 | 2024-05-10T00:10:00.000Z | qa
1.219419184511587  | 2024-05-10T00:20:00.000Z | qa
1.1905023332418336 | 2024-05-10T00:30:00.000Z | qa
0.9343173431734317 | 2024-05-10T00:10:00.000Z | staging
1.0426854537919603 | 2024-05-10T00:20:00.000Z | staging
0.9903225806451613 | 2024-05-10T00:30:00.000Z | staging
;

// INNER semantics: the denominator only has cluster=prod, so qa/staging have no match and are dropped.
vector_match_inner_drops_unmatched
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m ratio=(sum by (cluster) (network.eth0.tx) / on (cluster) sum by (cluster) (network.eth0.rx{cluster="prod"}))
| SORT cluster, step;

ratio:double       | step:datetime            | cluster:keyword
1.103305785123967  | 2024-05-10T00:10:00.000Z | prod
1.1411513859275053 | 2024-05-10T00:20:00.000Z | prod
1.16072408118486   | 2024-05-10T00:30:00.000Z | prod
;

// Many-to-one group_left: the "many" LHS is grouped by (cluster, pod); each pod's tx is divided by its cluster's
// summed rx (the "one" RHS grouped by cluster), which is broadcast across the pods of that cluster.
vector_match_group_left
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m ratio=(sum by (cluster, pod) (network.eth0.tx) / on (cluster) group_left sum by (cluster) (network.eth0.rx))
| SORT cluster, pod, step;

