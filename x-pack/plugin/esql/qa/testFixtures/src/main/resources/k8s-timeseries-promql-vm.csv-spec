// Focused REST coverage for both successful and failing vector matching queries lives in PromqlVectorMatchingIT.

///////////////////////////////////////////////////////////////////////////////
// Opaque-operand matrix: vector matching where one or both operands are opaque
// (a bare selector or a `without` aggregation packs its identity into
// `_timeseries` with no label columns of its own). The match key labels are
// demanded from the operand compilations and materialized alongside the packed
// identity. In this dataset (cluster, pod) uniquely identifies a series, so the
// raw-selector cases must numerically equal the sum by (cluster, pod) baseline.
// Per-series values at 2024-05-10T00:10: tx(prod) = one 409, three 361, two 298;
// rx(prod) = one 440, three 369, two 159.
///////////////////////////////////////////////////////////////////////////////

// Baseline: concrete/concrete on (cluster, pod).
vector_match_matrix_concrete_concrete
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(sum by (cluster, pod) (network.eth0.tx) / on (cluster, pod) sum by (cluster, pod) (network.eth0.rx))
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double           | cluster:keyword | pod:keyword | step:datetime
0.9295454545454546 | prod            | one         | 2024-05-10T00:10:00.000Z
0.978319783197832  | prod            | three       | 2024-05-10T00:10:00.000Z
1.8742138364779874 | prod            | two         | 2024-05-10T00:10:00.000Z
;

// Opaque/opaque: both keys are materialized from _timeseries, no regrouping.
vector_match_matrix_opaque_opaque_on
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(network.eth0.tx / on (cluster, pod) network.eth0.rx)
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double           | cluster:keyword | pod:keyword | step:datetime
0.9295454545454546 | prod            | one         | 2024-05-10T00:10:00.000Z
0.978319783197832  | prod            | three       | 2024-05-10T00:10:00.000Z
1.8742138364779874 | prod            | two         | 2024-05-10T00:10:00.000Z
;

// Opaque/concrete: hidden labels on the LHS become join keys.
vector_match_matrix_opaque_concrete
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(network.eth0.tx / on (cluster, pod) sum by (cluster, pod) (network.eth0.rx))
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double           | cluster:keyword | pod:keyword | step:datetime
0.9295454545454546 | prod            | one         | 2024-05-10T00:10:00.000Z
0.978319783197832  | prod            | three       | 2024-05-10T00:10:00.000Z
1.8742138364779874 | prod            | two         | 2024-05-10T00:10:00.000Z
;

// Concrete/opaque: hidden labels on the RHS become join keys.
vector_match_matrix_concrete_opaque
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(sum by (cluster, pod) (network.eth0.tx) / on (cluster, pod) network.eth0.rx)
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double           | cluster:keyword | pod:keyword | step:datetime
0.9295454545454546 | prod            | one         | 2024-05-10T00:10:00.000Z
