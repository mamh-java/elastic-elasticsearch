0.37293388429752067 | prod            | three       | 2024-05-10T00:10:00.000Z
0.30785123966942146 | prod            | two         | 2024-05-10T00:10:00.000Z
;

// Concrete one / opaque many: the RHS hidden labels survive through group_right.
// Same numbers as vector_match_group_right.
vector_match_matrix_opaque_many_group_right
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(sum by (cluster) (network.eth0.tx) / on (cluster) group_right (pod) network.eth0.rx)
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double           | cluster:keyword | pod:keyword | step:datetime
2.4272727272727272 | prod            | one         | 2024-05-10T00:10:00.000Z
2.894308943089431  | prod            | three       | 2024-05-10T00:10:00.000Z
6.716981132075472  | prod            | two         | 2024-05-10T00:10:00.000Z
;

// ignoring(...) with an opaque operand: the key set is the labels the operands
// declare minus the ignored ones - here the concrete RHS defines {cluster} - not
// a physical-column intersection. Same numbers as vector_match_group_left.
vector_match_matrix_opaque_ignoring
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(network.eth0.tx / ignoring (pod) group_left (pod) sum by (cluster) (network.eth0.rx))
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double            | cluster:keyword | pod:keyword | step:datetime
0.4225206611570248  | prod            | one         | 2024-05-10T00:10:00.000Z
0.37293388429752067 | prod            | three       | 2024-05-10T00:10:00.000Z
0.30785123966942146 | prod            | two         | 2024-05-10T00:10:00.000Z
;

// A `without` identity can still expose concrete join labels: without (pod)
// keeps (cluster, region) packed, and cluster is materialized for the key.
// Same numbers as vector_match_on_cluster.
vector_match_matrix_without_identity
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(sum without (pod) (network.eth0.tx) / on (cluster) sum by (cluster) (network.eth0.rx))
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, step;

r:double          | cluster:keyword | step:datetime
1.103305785123967 | prod            | 2024-05-10T00:10:00.000Z
;

// An outer aggregate consumes a joined opaque-lowered table: sum over the nine
// per-series ratios. ROUND guards against float summation-order jitter.
vector_match_matrix_nested_join
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(sum(network.eth0.tx / on (cluster, pod) network.eth0.rx))
| WHERE step == "2024-05-10T00:10:00.000Z"
| EVAL r = ROUND(r, 9)
| KEEP r, step;

r:double    | step:datetime
9.698298222 | 2024-05-10T00:10:00.000Z
;

// The same key lowering works for comparisons: 1.0 where tx > rx per series.
vector_match_matrix_comparison_bool
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(network.eth0.tx > bool on (cluster, pod) network.eth0.rx)
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double | cluster:keyword | pod:keyword | step:datetime
0.0      | prod            | one         | 2024-05-10T00:10:00.000Z
0.0      | prod            | three       | 2024-05-10T00:10:00.000Z
1.0      | prod            | two         | 2024-05-10T00:10:00.000Z
;

// The semi-join path uses the same key lowering: every tx series has a matching
// rx series, so all LHS values survive unchanged.
vector_match_matrix_and
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m r=(network.eth0.tx and on (cluster, pod) network.eth0.rx)
| WHERE cluster == "prod" AND step == "2024-05-10T00:10:00.000Z"
| KEEP r, cluster, pod, step
| SORT pod;

r:double | cluster:keyword | pod:keyword | step:datetime
409.0    | prod            | one         | 2024-05-10T00:10:00.000Z
361.0    | prod            | three       | 2024-05-10T00:10:00.000Z
298.0    | prod            | two         | 2024-05-10T00:10:00.000Z
;
