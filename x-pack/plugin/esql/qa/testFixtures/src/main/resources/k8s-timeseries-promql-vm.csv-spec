// Bool-mode comparison: 1.0 where tx > rx for the matched (cluster, step), else 0.0; no rows dropped.
vector_match_comparison_bool
required_capability: promql_vector_matching_v0
PROMQL index=k8s step=10m result=(sum by (cluster) (network.eth0.tx) > bool on (cluster) sum by (cluster) (network.eth0.rx))
| SORT cluster, step;

